# Copy to .env and edit. All paths are on the HOST.

# Path to your local clone of https://github.com/antirez/ds4 (build.sh compiles here).
DS4_SRC=/path/to/ds4

# GPU compute capability / nvcc -arch value:
#   sm_110  Jetson AGX Thor            (tested)
#   sm_121  DGX Spark (GB10)           (should work; untested here)
#   native  let nvcc auto-detect the local GPU
# Check yours with: nvidia-smi --query-gpu=compute_cap --format=csv
DS4_CUDA_ARCH=sm_110

# Host CUDA toolkit dir to bind-mount read-only into the container.
# Must provide libcudart/libcublas/libcublasLt matching what ds4 links against.
CUDA_DIR=/usr/local/cuda

# Absolute path to your downloaded GGUF model (see ds4's download_model.sh).
# REQUIRED — there is no default.
MODEL_PATH=/abs/path/to/model.gguf

# Server context window (tokens). Keep in sync with your client/agent's setting.
DS4_CTX=65536

# Published host port for the OpenAI-compatible API.
DS4_PORT=8000

# Disk KV cache: budget (MiB) and the max cold-prompt length to checkpoint.
KV_BUDGET_MB=16384
KV_COLD_MAX=65000

# Host dirs for KV checkpoints and (optional) traces. Relative paths are fine.
KV_DIR=./kv-cache
LOG_DIR=./logs
